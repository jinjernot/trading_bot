# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
env/

# ── Secrets & credentials (NEVER commit) ─────────────────────────
config
.env
.env.*

# ── Python cache ──────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python

